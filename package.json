{
  "name": "skill-zoo-workspace",
  "version": "0.3.19",
  "description": "Local GUI tool for managing Agent Skills",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun vite build",
    "tauri": "bunx tauri",
    "typecheck": "bunx tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --deny=correctness --deny=suspicious --deny=perf src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "lint:rs": "cargo clippy --manifest-path src-tauri/Cargo.toml --features test-helpers -- -D warnings",
    "format:rs": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:rs:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "test:rs": "cargo test --manifest-path src-tauri/Cargo.toml --features test-helpers",
    "cli:build": "cd packages/cli && bun run build",
    "cli:test": "cd packages/cli && bun run test",
    "cli:typecheck": "cd packages/cli && bun run typecheck",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-query": "^5.101.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "highlight.js": "^11.11.1",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "js-yaml": "^5.2.1",
    "lucide-react": "^1.23.0",
    "modern-screenshot": "^4.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
