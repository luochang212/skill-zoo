{
  "name": "skill-zoo-workspace",
  "version": "0.3.9",
  "description": "Local GUI tool for managing Agent Skills",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun vite build",
    "tauri": "bunx tauri",
    "typecheck": "bunx tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --deny=correctness --deny=suspicious --deny=perf src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "lint:rs": "cargo clippy --manifest-path src-tauri/Cargo.toml --features test-helpers -- -D warnings",
    "format:rs": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:rs:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "test:rs": "cargo test --manifest-path src-tauri/Cargo.toml --features test-helpers",
    "cli:build": "cd packages/cli && bun run build",
    "cli:test": "cd packages/cli && bun run test",
    "cli:typecheck": "cd packages/cli && bun run typecheck"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.100.6",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "framer-motion": "^12.38.0",
    "highlight.js": "^11.11.1",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "js-yaml": "^4.2.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
