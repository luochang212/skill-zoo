{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Default capabilities for Skill Zoo",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "dialog:allow-open",
    "opener:default",
    "opener:allow-open-path",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
